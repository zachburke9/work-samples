# Copy this file to .env and fill in real values. Do not commit .env.
# Read by email_alerts.SmtpSettings.from_env().
ALERT_SMTP_HOST=smtp.example.com
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=alerts@example.com
ALERT_SMTP_PASSWORD=replace-with-app-password
ALERT_SENDER=alerts@example.com
ALERT_RECIPIENT=data-team@example.com
